# Server
PORT=8080
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://root:password@localhost:27017/artnepalaya?authSource=admin

# PostgreSQL
POSTGRES_URI=postgresql://postgres:password@localhost:5432/artnepalaya

# Redis
REDIS_URL=redis://localhost:6380

# JWT (minimum 32 characters each)
JWT_ACCESS_SECRET=your-jwt-access-secret-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-change-in-production-min-32-chars

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
